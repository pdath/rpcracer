#!/bin/sh
# configure script for rpcrace
# Detects pkg-config, libzmq, required headers, and architecture
# Writes config.mk with detected paths and flags

set -e

echo "Configuring rpcrace..."

# Colors for output (if terminal supports it)
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

error() {
    printf "${RED}ERROR: %s${NC}\n" "$1" >&2
    exit 1
}

ok() {
    printf "${GREEN}OK${NC}\n"
}

# Detect architecture
printf "Checking architecture... "
ARCH=$(uname -m)
case "$ARCH" in
    x86_64|aarch64)
        echo "$ARCH"
        ;;
    *)
        error "Unsupported architecture: $ARCH (need x86_64 or aarch64)"
        ;;
esac

# Check for pkg-config
printf "Checking for pkg-config... "
if ! command -v pkg-config >/dev/null 2>&1; then
    error "pkg-config not found. Install with: apt-get install pkg-config"
fi
ok

# Check for gcc
printf "Checking for gcc... "
if ! command -v gcc >/dev/null 2>&1; then
    error "gcc not found. Install with: apt-get install gcc"
fi
GCC_VERSION=$(gcc -dumpversion)
echo "$GCC_VERSION"

# Check for libzmq via pkg-config
printf "Checking for libzmq... "
if ! pkg-config --exists libzmq; then
    error "libzmq not found. Install with: apt-get install libzmq3-dev"
fi
ZMQ_CFLAGS=$(pkg-config --cflags libzmq)
ZMQ_LIBS=$(pkg-config --libs libzmq)
ZMQ_VERSION=$(pkg-config --modversion libzmq)
echo "$ZMQ_VERSION"

# Check for required headers
check_header() {
    printf "Checking for %s... " "$1"
    cat > /tmp/rpcrace_conftest.c <<EOF
#include <$1>
int main(void) { return 0; }
EOF
    if gcc $ZMQ_CFLAGS -c /tmp/rpcrace_conftest.c -o /tmp/rpcrace_conftest.o 2>/dev/null; then
        ok
        rm -f /tmp/rpcrace_conftest.c /tmp/rpcrace_conftest.o
    else
        rm -f /tmp/rpcrace_conftest.c /tmp/rpcrace_conftest.o
        error "Header $1 not found"
    fi
}

check_header "zmq.h"
check_header "sys/epoll.h"

# Write config.mk
printf "Writing config.mk... "
cat > config.mk <<EOF
# Generated by configure on $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Architecture: $ARCH

ARCH = $ARCH
ZMQ_CFLAGS = $ZMQ_CFLAGS
ZMQ_LIBS = $ZMQ_LIBS
EOF
ok

echo ""
echo "Configuration complete. Run 'make' to build."
